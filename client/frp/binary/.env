# FRP 客户端 (FRPC) 配置 - 二进制运行方式

# FRP 服务器地址
FRPS_SERVER=你的服务器IP

# FRP 服务器端口
FRPS_PORT=7000

# 认证 Token (和服务端 FRPS_AUTH_TOKEN 一致)
FRPS_TOKEN=your_frp_token_here

# 二进制文件路径 (自动下载后填写)
FRPC_BINARY=./frpc

# 系统架构 (自动检测或手动设置: linux_amd64, linux_arm64, darwin_amd64, windows_amd64)
ARCH=auto

# ==========================================
# 运行模式选择
# ==========================================
# true: 使用配置文件 (frpc.toml)
# false: 使用命令行参数 (单隧道)
USE_CONFIG_FILE=false

# 单隧道模式配置 (当 USE_CONFIG_FILE=false 时生效)
FRPC_REMOTE_PORT=7001
FRPC_LOCAL_PORT=8080

# 配置文件名 (当 USE_CONFIG_FILE=true 时生效)
FRPC_CONFIG_FILE=frpc.toml
