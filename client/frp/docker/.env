# FRP 客户端 (FRPC) 配置 - Docker 方式

# FRP 服务器地址
FRPS_SERVER=你的服务器IP

# FRP 服务器端口
FRPS_PORT=7000

# 认证 Token (和服务端 FRPS_AUTH_TOKEN 一致)
FRPS_TOKEN=your_frp_token_here

# 容器名称
CONTAINER_NAME=frpc

# ==========================================
# 单隧道模式 (简单场景)
# ==========================================
# 如果使用命令行参数方式，配置以下项
FRPC_REMOTE_PORT=7001           # 远程端口 (服务端开放的端口)
FRPC_LOCAL_PORT=8080            # 本地服务端口

# ==========================================
# 多隧道模式 (高级场景)
# ==========================================
# 如果使用配置文件方式，设置为 true
USE_CONFIG_FILE=false

# 配置文件名 (当 USE_CONFIG_FILE=true 时生效)
FRPC_CONFIG_FILE=frpc.toml
